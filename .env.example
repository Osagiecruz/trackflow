# ─── DATABASE ────────────────────────────────────────────
POSTGRES_DB=trackflow
POSTGRES_USER=trackflow
POSTGRES_PASSWORD=change_me_strong_password_here

# ─── REDIS ───────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── JWT AUTH ────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_random_string_openssl_rand_hex_64
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string

# ─── DOMAIN ──────────────────────────────────────────────
DOMAIN=trackflow.io

# ─── TWILIO (SMS notifications) ──────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── SENDGRID (Email notifications) ──────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@trackflow.io
SENDGRID_FROM_NAME=TrackFlow

# ─── CARRIER APIs ────────────────────────────────────────
# DHL: https://developer.dhl.com
DHL_API_KEY=your_dhl_api_key
DHL_API_SECRET=your_dhl_api_secret

# FedEx: https://developer.fedex.com
FEDEX_API_KEY=your_fedex_api_key
FEDEX_API_SECRET=your_fedex_api_secret

# UPS: https://developer.ups.com
UPS_CLIENT_ID=your_ups_client_id
UPS_CLIENT_SECRET=your_ups_client_secret

# ─── MAPBOX ──────────────────────────────────────────────
# Get from: https://account.mapbox.com
VITE_MAPBOX_TOKEN=pk.eyJ1IjoieW91cnVzZXJuYW1lIiwiYSI6ImNr...

# ─── GITHUB (for CI/CD) ──────────────────────────────────
GITHUB_REPOSITORY=yourorg/trackflow
IMAGE_TAG=latest
